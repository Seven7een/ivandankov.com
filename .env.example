# Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# Site configuration
SITE_URL=http://localhost:4321
SITE_TITLE=Ivan Dankov

# Dev server (optional — omit for default localhost HTTP)
# DEV_HOST=0.0.0.0
# DEV_TLS_KEY=/path/to/key.pem
# DEV_TLS_CERT=/path/to/cert.pem

# Contact form (Vercel serverless function + Gmail SMTP)
# Create a Google App Password: Google Account > Security > App Passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_EMAIL=
