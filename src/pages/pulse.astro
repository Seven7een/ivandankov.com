---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());
---

<Layout title="Pulse">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">Pulse</h1>

    {posts.length === 0 && (
      <p class="text-[var(--color-text-secondary)]">No posts yet. Add MDX files to <code class="text-[var(--color-accent)]">src/content/blog/</code>.</p>
    )}

    <div class="grid gap-4">
      {posts.map((post) => (
        <Card
          href={`/pulse/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          tags={post.data.tags}
          datetime={post.data.pubDatetime.toISOString()}
        />
      ))}
    </div>
  </section>
</Layout>
