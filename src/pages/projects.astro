---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());
---

<Layout title="Projects">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">Projects</h1>

    {projects.length === 0 && (
      <p class="text-[var(--color-text-secondary)]">No projects yet. Add MDX files to <code class="text-[var(--color-accent)]">src/content/projects/</code>.</p>
    )}

    <div class="grid gap-4">
      {projects.map((project) => (
        <Card
          href={`/projects/${project.id}`}
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          datetime={project.data.pubDatetime.toISOString()}
        />
      ))}
    </div>
  </section>
</Layout>
