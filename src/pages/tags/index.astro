---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const posts = await getCollection('blog');
const projects = await getCollection('projects');

const allTags = [...new Set([
  ...posts.flatMap((p) => p.data.tags),
  ...projects.flatMap((p) => p.data.tags),
])].sort();
---

<Layout title="Tags">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold">Tags</h1>

    {allTags.length === 0 && (
      <p class="text-gray-500">No tags yet.</p>
    )}

    <div class="flex flex-wrap gap-3">
      {allTags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="text-sm bg-gray-100 text-gray-700 px-3 py-1.5 rounded hover:bg-blue-50 hover:text-blue-600 transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
  </section>
</Layout>
