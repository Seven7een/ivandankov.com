---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title} description={project.data.description}>
  <article class="space-y-6">
    <a href="/projects" class="text-sm text-blue-600 hover:underline">&larr; Back to Projects</a>

    <h1 class="text-3xl font-bold">{project.data.title}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg text-sm">
      <div>
        <span class="font-semibold">Problem:</span>
        <p class="text-gray-600 mt-1">{project.data.problem}</p>
      </div>
      <div>
        <span class="font-semibold">Solution:</span>
        <p class="text-gray-600 mt-1">{project.data.solution}</p>
      </div>
    </div>

    <div class="flex gap-2">
      {project.data.tags.map((tag) => (
        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">{tag}</span>
      ))}
    </div>

    <div class="prose prose-gray max-w-none">
      <Content />
    </div>
  </article>
</Layout>
