---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';
import { SITE } from '@/consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const featuredPosts = posts.filter((p) => p.data.featured);
const recentPosts = posts.filter((p) => !p.data.featured).slice(0, SITE.postPerIndex);
---

<Layout>
  <section class="space-y-6">
    <h1 class="text-3xl font-bold text-[var(--color-text-primary)]">Welcome</h1>
    <p class="text-lg text-[var(--color-text-secondary)]">
      This is a placeholder site scaffolded by The Forge. Edit this page to get started.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <a href="/projects" class="block p-6 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)] transition-colors">
        <h2 class="font-semibold text-lg text-[var(--color-text-primary)]">Projects</h2>
        <p class="text-[var(--color-text-secondary)] text-sm mt-1">View project showcases</p>
      </a>
      <a href="/pulse" class="block p-6 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)] transition-colors">
        <h2 class="font-semibold text-lg text-[var(--color-text-primary)]">Pulse</h2>
        <p class="text-[var(--color-text-secondary)] text-sm mt-1">Read blog posts and updates</p>
      </a>
    </div>
  </section>

  {featuredPosts.length > 0 && (
    <section class="mt-12 space-y-4">
      <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Featured</h2>
      <div class="grid gap-4">
        {featuredPosts.map((post) => (
          <Card
            href={`/pulse/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
            datetime={post.data.pubDatetime.toISOString()}
          />
        ))}
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="mt-12 space-y-4">
      <h2 class="text-2xl font-semibold text-[var(--color-text-primary)]">Recent Posts</h2>
      <div class="grid gap-4">
        {recentPosts.map((post) => (
          <Card
            href={`/pulse/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
            datetime={post.data.pubDatetime.toISOString()}
          />
        ))}
      </div>
    </section>
  )}
</Layout>
