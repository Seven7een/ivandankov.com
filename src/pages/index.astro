---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Card from '@/components/Card.astro';
import BadgeBar from '@/components/BadgeBar.astro';
import BentoGrid from '@/components/BentoGrid.astro';
import { SITE } from '@/consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const featuredProjects = projects.filter((p) => p.data.featured);
const featuredPosts = posts.filter((p) => p.data.featured);
const recentPosts = posts.filter((p) => !p.data.featured).slice(0, SITE.postPerIndex);

const bentoItems = [
  {
    label: 'Current Stack',
    value: 'AWS, Linux, Python, Bash',
    detail: 'Finding the best tool for the job',
  },
  {
    label: 'Primary Focus',
    value: 'DevSecOps & Security Engineering',
    detail: 'Security-first infrastructure at scale',
  },
  {
    label: 'Recent Side Project',
    value: 'Shellmate',
    detail: 'AI-powered Linux CLI assistant built on AWS Bedrock',
    href: '/projects/shellmate',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="flex flex-row items-start gap-5 sm:gap-8 mb-10">
    <img
      src="/assets/headshot.jpg"
      alt="Ivan Dankov"
      width="160"
      height="160"
      class="rounded-xl w-28 h-28 sm:w-40 sm:h-40 object-cover shrink-0"
    />
    <div class="space-y-2 sm:space-y-3 min-w-0">
      <h1 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)]">Ivan Dankov</h1>
      <p class="text-sm sm:text-lg text-[var(--color-text-secondary)]">
        Senior Engineer at the messy intersection of cybersecurity, distributed systems, and observability.
      </p>
      <p class="hidden sm:block text-sm text-[var(--color-text-muted)]">
        Vienna & London &middot; Linux fan &middot; Spaces over tabs
      </p>
    </div>
  </section>
  <p class="sm:hidden text-xs text-[var(--color-text-muted)] -mt-6 mb-10">
    Vienna & London &middot; Linux fan &middot; Spaces over tabs
  </p>

  <!-- Badges -->
  <section class="mb-10">
    <BadgeBar />
  </section>

  <!-- Quick Stats -->
  <section class="mb-12">
    <BentoGrid items={bentoItems} />
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="mb-12 space-y-4">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Featured Projects</h2>
      <div class="grid gap-4">
        {featuredProjects.map((project) => (
          <Card
            href={`/projects/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            datetime={project.data.pubDatetime.toISOString()}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="mb-12 space-y-4">
      <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Featured Posts</h2>
      <div class="grid gap-4">
        {featuredPosts.map((post) => (
          <Card
            href={`/pulse/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
            datetime={post.data.pubDatetime.toISOString()}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">Recent Posts</h2>
        <a href="/pulse" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">View all &rarr;</a>
      </div>
      <div class="grid gap-4">
        {recentPosts.map((post) => (
          <Card
            href={`/pulse/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
            datetime={post.data.pubDatetime.toISOString()}
          />
        ))}
      </div>
    </section>
  )}
</Layout>
