---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Not Found">
  <section class="text-center py-20">
    <h1 class="text-6xl font-bold text-[var(--color-text-muted)]">404</h1>
    <p class="text-lg text-[var(--color-text-secondary)] mt-4">Page not found.</p>
    <a href="/" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] hover:underline mt-6 inline-block">Go home</a>
  </section>
</Layout>
