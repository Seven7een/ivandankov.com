---
interface BentoItem {
  label: string;
  value: string;
  detail?: string;
  href?: string;
}

interface Props {
  items: BentoItem[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  {items.map(({ label, value, detail, href }) => {
    const Tag = href ? 'a' : 'div';
    return (
      <Tag
        href={href}
        class:list={[
          'block p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)]',
          href && 'hover:border-[var(--color-border-hover)] hover:bg-[var(--color-bg-hover)] transition-colors',
        ]}
      >
        <p class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">{label}</p>
        <p class="text-[var(--color-text-primary)] font-medium">{value}</p>
        {detail && (
          <p class="text-sm text-[var(--color-text-secondary)] mt-1">{detail}</p>
        )}
      </Tag>
    );
  })}
</div>
