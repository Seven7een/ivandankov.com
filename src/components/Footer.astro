---
import { SITE, SOCIAL_LINKS } from '@/consts';
---

<footer class="border-t border-[var(--color-border)] px-6 py-8 mt-16">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-muted)]">
    <p>&copy; {new Date().getFullYear()} {SITE.title}</p>
    {SOCIAL_LINKS.length > 0 && (
      <div class="flex gap-4">
        {SOCIAL_LINKS.map(({ href, label }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-accent)] transition-colors"
          >
            {label}
          </a>
        ))}
      </div>
    )}
  </div>
</footer>
